            "kind": "GaugeChart",
            "spec": {
              "calculation": "last-number",
              "format": {
                "decimalPlaces": 4,
                "unit": "percent-decimal"
              },
              "max": 1,
              "thresholds": {
                "steps": [
                  {
                    "color": "#f2495c",
                    "value": 0
                  },
                  {
                    "color": "#ff9830",
                    "value": 0.99
                  },
                  {
                    "color": "#fade2a",
                    "value": 0.995
                  },
                  {
                    "color": "#73bf69",
                    "value": 0.999
                  }
                ]
              }
