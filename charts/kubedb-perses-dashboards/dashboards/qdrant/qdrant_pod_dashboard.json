              "yAxis": {
                "format": {
                  "unit": "requests/sec"
                }
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "minStep": "",
                    "query": "rate(grpc_responses_total{namespace=~\"$namespace\",service=~\"$app+-stats\",pod=~\"$pod\"}[5m])",
                    "seriesNameFormat": "{{ `{{endpoint}}` }}"
                  }
                }
              }
            }
          ]
        }
      },
