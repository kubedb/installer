                  "spec": {
                    "minStep": "",
                    "query": "sum(\n  rate(ClickHouseProfileEvents_Query{namespace=~\"$namespace\", service=~\"$app+-stats\"}[1h])\n)\n",
                    "seriesNameFormat": ""
                  }
                }
              }
            }
          ]
        }
      },
